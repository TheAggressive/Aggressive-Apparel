# Copy to `.env.local` (gitignored) for local i18n MT tooling.
# Never commit real keys. CI uses GitHub Actions secrets instead.
#
#   cp .env.example .env.local

# Optional DeepL API key (Free keys end with `:fx`).
# Used as MyMemory backup, or as sole provider when I18N_MT_PROVIDER=deepl.
DEEPL_AUTH_KEY=

# mymemory (default) | deepl
# I18N_MT_PROVIDER=mymemory

# Optional: raises MyMemory daily character quota.
# I18N_MT_EMAIL=you@example.com

# Optional: delay between MT requests (ms).
# I18N_MT_DELAY_MS=350
