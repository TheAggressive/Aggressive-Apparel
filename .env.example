# Copy to `.env.local` (gitignored) for local i18n MT tooling.
# Never commit real keys. CI uses GitHub Actions secrets instead.
#
#   cp .env.example .env.local

# Recommended DeepL API key (Free keys end with `:fx`).
# Primary MT provider. Without it, MT falls back to MyMemory, which is
# noticeably rougher on short UI labels.
DEEPL_AUTH_KEY=

# auto (default: DeepL first, MyMemory fallback) | mymemory | deepl (no fallback)
# I18N_MT_PROVIDER=auto

# Optional: raises MyMemory daily character quota (fallback path only).
# I18N_MT_EMAIL=you@example.com

# Optional: delay between MT requests (ms).
# I18N_MT_DELAY_MS=350
