{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/card-flip",
  "version": "2.0.0",
  "title": "Card Flip",
  "category": "aggressive-apparel",
  "description": "A card with two faces that flips to reveal the back. Accessible button-driven disclosure, with an optional hover flip.",
  "keywords": ["card", "flip", "3d", "product", "reveal"],
  "allowedBlocks": [
    "aggressive-apparel/card-flip-front",
    "aggressive-apparel/card-flip-back"
  ],
  "supports": {
    "html": false,
    "interactivity": true,
    "align": ["wide"],
    "dimensions": {
      "aspectRatio": true
    },
    "spacing": {
      "margin": true
    },
    "__experimentalBorder": {
      "radius": true,
      "width": true,
      "color": true,
      "style": true
    },
    "shadow": true
  },
  "attributes": {
    "flipOn": {
      "type": "string",
      "enum": ["hover", "click"],
      "default": "hover"
    }
  },
  "textdomain": "aggressive-apparel",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScriptModule": "file:./view.js"
}
