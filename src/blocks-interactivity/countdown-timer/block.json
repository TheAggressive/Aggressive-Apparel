{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/countdown-timer",
  "version": "1.0.0",
  "title": "Sale Countdown Timer",
  "category": "woocommerce",
  "description": "Live countdown for products with a scheduled sale end date. Place on the single product template.",
  "keywords": ["countdown", "sale", "timer", "urgency"],
  "supports": {
    "html": false,
    "interactivity": true
  },
  "attributes": {
    "dropPageUrl": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "aggressive-apparel",
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScriptModule": "file:./view.js"
}
