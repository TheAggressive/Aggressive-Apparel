{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/ticker",
  "version": "1.0.0",
  "title": "Ticker",
  "category": "widgets",
  "icon": "slides",
  "description": "Infinite scrolling marquee for text, logos, or any content. Add the Free Shipping Message block for live cart thresholds.",
  "supports": {
    "html": false,
    "interactivity": true,
    "align": ["wide", "full"],
    "color": {
      "text": true,
      "background": true,
      "gradients": true
    },
    "spacing": {
      "padding": true,
      "margin": true
    },
    "typography": {
      "fontSize": true,
      "lineHeight": true
    }
  },
  "attributes": {
    "speed": {
      "type": "number",
      "default": 30
    },
    "direction": {
      "type": "string",
      "default": "left"
    },
    "pauseOnHover": {
      "type": "boolean",
      "default": true
    },
    "gap": {
      "type": "number",
      "default": 48
    },
    "fadeEdges": {
      "type": "boolean",
      "default": false
    },
    "fadeWidth": {
      "type": "number",
      "default": 64
    },
    "showLabel": {
      "type": "boolean",
      "default": false
    },
    "labelText": {
      "type": "string",
      "default": "LIVE"
    },
    "labelBg": {
      "type": "string",
      "default": ""
    },
    "labelColor": {
      "type": "string",
      "default": ""
    },
    "showIndicator": {
      "type": "boolean",
      "default": true
    },
    "indicatorShape": {
      "type": "string",
      "default": "square"
    },
    "indicatorColor": {
      "type": "string",
      "default": ""
    },
    "pattern": {
      "type": "string",
      "default": "none"
    },
    "patternColor": {
      "type": "string",
      "default": ""
    },
    "patternBlendMode": {
      "type": "string",
      "default": "normal"
    },
    "patternOpacity": {
      "type": "number",
      "default": 100
    },
    "patternScale": {
      "type": "number",
      "default": 100
    },
    "labelFontSize": {
      "type": "number",
      "default": 0
    },
    "labelFontWeight": {
      "type": "string",
      "default": ""
    },
    "labelLetterSpacing": {
      "type": "number",
      "default": 0
    },
    "labelTextTransform": {
      "type": "string",
      "default": ""
    }
  },
  "textdomain": "aggressive-apparel",
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php",
  "viewScriptModule": "file:./view.js"
}
