{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/copyright",
  "version": "1.4.0",
  "title": "Copyright",
  "category": "aggressive-apparel",
  "description": "Dynamic copyright notice with legal identity, Schema.org markup, and Privacy/Terms links.",
  "keywords": [
    "copyright",
    "year",
    "footer",
    "legal",
    "llc",
    "inc",
    "privacy",
    "terms"
  ],
  "textdomain": "aggressive-apparel",
  "attributes": {
    "ownerSource": {
      "type": "string",
      "default": "site_title",
      "enum": ["site_title", "legal_name", "custom"]
    },
    "ownerName": {
      "type": "string",
      "default": ""
    },
    "legalEntity": {
      "type": "string",
      "default": ""
    },
    "legalEntityCustom": {
      "type": "string",
      "default": ""
    },
    "showStartYear": {
      "type": "boolean",
      "default": false
    },
    "startYear": {
      "type": "number",
      "default": 2024
    },
    "separator": {
      "type": "string",
      "default": "–"
    },
    "prefix": {
      "type": "string",
      "default": "©"
    },
    "suffix": {
      "type": "string",
      "default": ""
    },
    "showLegalLinks": {
      "type": "boolean",
      "default": false
    },
    "legalLinksSeparator": {
      "type": "string",
      "default": "|",
      "enum": ["|", "·", "•", "–", "-", "/"]
    },
    "showSchema": {
      "type": "boolean",
      "default": true
    },
    "textAlign": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "anchor": true,
    "color": {
      "text": true,
      "background": true
    },
    "typography": {
      "fontSize": true,
      "fontFamily": true,
      "fontWeight": true,
      "lineHeight": true,
      "letterSpacing": true,
      "textDecoration": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    },
    "className": true
  },
  "example": {
    "attributes": {
      "ownerSource": "custom",
      "ownerName": "Aggressive Apparel",
      "legalEntity": "LLC",
      "suffix": ". All rights reserved.",
      "showLegalLinks": true
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
