{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/product-rating",
  "version": "1.0.0",
  "title": "Aggressive Star Rating",
  "category": "woocommerce",
  "description": "Product rating rendered with the Aggressive brand mark instead of stars.",
  "keywords": ["rating", "reviews", "stars", "product", "aggressive"],
  "textdomain": "aggressive-apparel",
  "icon": "star-filled",
  "usesContext": ["postId", "query", "queryId"],
  "attributes": {
    "isDescendentOfSingleProductTemplate": {
      "type": "boolean",
      "default": false
    },
    "textAlign": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "spacing": {
      "margin": true,
      "padding": true
    },
    "className": true
  },
  "editorScript": "file:./index.js",
  "style": "file:./style-index.css",
  "render": "file:./render.php"
}
