{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "aggressive-apparel/split-story-media",
  "version": "1.0.0",
  "title": "Story Media",
  "category": "aggressive-apparel",
  "description": "The sticky media column of a Split Story. Add an image, video, or any blocks.",
  "parent": ["aggressive-apparel/split-story"],
  "keywords": ["split", "story", "media", "sticky"],
  "supports": {
    "html": false,
    "reusable": false,
    "inserter": false,
    "className": true,
    "color": {
      "background": true,
      "text": true,
      "gradients": true
    },
    "spacing": {
      "margin": true,
      "padding": true,
      "blockGap": true
    },
    "border": {
      "color": true,
      "radius": true,
      "style": true,
      "width": true
    },
    "layout": true
  },
  "textdomain": "aggressive-apparel",
  "editorScript": "file:./index.js"
}
