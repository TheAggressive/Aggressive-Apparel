{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "High Contrast",
  "slug": "high-contrast",
  "settings": {
    "custom": {
      "adaptiveColors": [
        {
          "slug": "surface",
          "name": "Background",
          "light": "oklch(100% 0 0)",
          "dark": "oklch(0% 0 0)"
        },
        {
          "slug": "surface-elevated",
          "name": "Background Elevated",
          "light": "oklch(96% 0 0)",
          "dark": "oklch(8% 0 0)"
        },
        {
          "slug": "foreground",
          "name": "Text",
          "light": "oklch(0% 0 0)",
          "dark": "oklch(100% 0 0)"
        },
        {
          "slug": "foreground-muted",
          "name": "Text Muted",
          "light": "oklch(40% 0 0)",
          "dark": "oklch(75% 0 0)"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "light": "oklch(44.4% 0.177 26.899)",
          "dark": "oklch(65% 0.245 27.325)"
        },
        {
          "slug": "border",
          "name": "Border",
          "light": "oklch(55% 0 0)",
          "dark": "oklch(55% 0 0)"
        }
      ],
      "radius": {
        "button": "0.125rem",
        "control": "0.125rem",
        "panel": "0.125rem",
        "card": "0.125rem"
      }
    }
  },
  "styles": {
    "elements": {
      "button": {
        "border": {
          "radius": "0.375rem"
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "800"
        }
      }
    },
    "blocks": {
      "core/separator": {
        "color": {
          "background": "var:preset|color|foreground"
        }
      }
    }
  }
}
