{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Minimal",
  "slug": "minimal",
  "settings": {
    "custom": {
      "adaptiveColors": [
        {
          "slug": "surface",
          "name": "Background",
          "light": "oklch(98% 0 0)",
          "dark": "oklch(15% 0 0)"
        },
        {
          "slug": "surface-elevated",
          "name": "Background Elevated",
          "light": "oklch(100% 0 0)",
          "dark": "oklch(10% 0 0)"
        },
        {
          "slug": "foreground",
          "name": "Text",
          "light": "oklch(25% 0 0)",
          "dark": "oklch(95% 0 0)"
        },
        {
          "slug": "foreground-muted",
          "name": "Text Muted",
          "light": "oklch(50% 0 0)",
          "dark": "oklch(70% 0 0)"
        },
        {
          "slug": "accent",
          "name": "Accent",
          "light": "oklch(44.4% 0.177 26.899)",
          "dark": "oklch(57.7% 0.245 27.325)"
        },
        {
          "slug": "border",
          "name": "Border",
          "light": "oklch(85% 0 0)",
          "dark": "oklch(30% 0 0)"
        }
      ],
      "radius": {
        "button": "0.25rem",
        "control": "0.25rem",
        "panel": "0.375rem",
        "card": "0.25rem"
      }
    }
  },
  "styles": {
    "elements": {
      "button": {
        "border": {
          "radius": "0.25rem"
        },
        "typography": {
          "textTransform": "none",
          "letterSpacing": "0.02em",
          "fontWeight": "500"
        }
      },
      "heading": {
        "typography": {
          "fontWeight": "600",
          "textTransform": "none"
        },
        "color": {
          "text": "var:preset|color|foreground"
        }
      },
      "link": {
        "typography": {
          "textDecoration": "underline"
        }
      }
    },
    "blocks": {
      "core/site-title": {
        "typography": {
          "textTransform": "none",
          "fontWeight": "600"
        }
      },
      "core/navigation": {
        "typography": {
          "textTransform": "none",
          "fontWeight": "400",
          "letterSpacing": "0"
        }
      }
    }
  }
}
