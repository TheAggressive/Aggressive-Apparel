{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Noir",
  "description": "High-contrast monochrome with sharp corners. A harder, editorial take on the brand — black-and-white surfaces, mono accents, zero radius.",
  "settings": {
    "custom": {
      "radius": {
        "sm": "0px",
        "md": "0px",
        "lg": "0px",
        "full": "0px",
        "button": "0px",
        "control": "0px",
        "panel": "0px",
        "card": "0px"
      },
      "adaptiveColors": [
        {
          "slug": "surface",
          "name": "Surface (Adaptive)",
          "light": "oklch(98% 0 0)",
          "dark": "oklch(12% 0 0)"
        },
        {
          "slug": "surface-elevated",
          "name": "Surface Elevated (Adaptive)",
          "light": "oklch(100% 0 0)",
          "dark": "oklch(16% 0 0)"
        },
        {
          "slug": "foreground",
          "name": "Foreground (Adaptive)",
          "light": "oklch(10% 0 0)",
          "dark": "oklch(98% 0 0)"
        },
        {
          "slug": "foreground-muted",
          "name": "Foreground Muted (Adaptive)",
          "light": "oklch(45% 0 0)",
          "dark": "oklch(68% 0 0)"
        },
        {
          "slug": "accent",
          "name": "Accent (Adaptive)",
          "light": "oklch(10% 0 0)",
          "dark": "oklch(98% 0 0)"
        },
        {
          "slug": "border",
          "name": "Border (Adaptive)",
          "light": "oklch(80% 0 0)",
          "dark": "oklch(35% 0 0)"
        }
      ]
    }
  }
}
