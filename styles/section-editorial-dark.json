{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 3,
  "title": "Section: Editorial Dark",
  "slug": "section-editorial-dark",
  "blockTypes": ["core/group", "core/columns", "core/media-text", "core/cover"],
  "styles": {
    "color": {
      "background": "var:preset|color|black",
      "text": "var:preset|color|white"
    },
    "spacing": {
      "padding": {
        "top": "var:preset|spacing|fluid-20",
        "right": "var:preset|spacing|fluid-12",
        "bottom": "var:preset|spacing|fluid-20",
        "left": "var:preset|spacing|fluid-12"
      }
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var:preset|color|white"
        }
      },
      "link": {
        "color": {
          "text": "var:preset|color|white"
        },
        ":hover": {
          "color": {
            "text": "var:preset|color|accent"
          }
        }
      },
      "button": {
        "border": {
          "color": "var:preset|color|white"
        },
        "color": {
          "background": "var:preset|color|white",
          "text": "var:preset|color|black"
        },
        ":hover": {
          "color": {
            "background": "var:preset|color|accent",
            "text": "var:preset|color|white"
          }
        }
      }
    }
  }
}
